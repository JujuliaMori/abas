<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pilha Centralizada 3D</title>
    <style>
        body {
            margin: 0;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background-color: #4b0082;
            font-family: 'Segoe UI', sans-serif;
            overflow: hidden;
        }

        /* Bola Amarela Centralizada */
        .circle-container {
            width: 450px;
            height: 450px;
            background: #ffcc00;
            border-radius: 50%;
            display: flex;
            justify-content: center; /* Centraliza horizontalmente */
            align-items: center;     /* Centraliza verticalmente */
            position: relative;
            box-shadow: 0 25px 60px rgba(0, 0, 0, 0.4);
            cursor: pointer;
        }

        /* Wrapper da Pilha */
        .stack-wrapper {
            position: relative;
            display: flex;
            justify-content: center;
            align-items: center;
            transition: all 0.7s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        /* Folhas */
        .sheet {
            position: absolute;
            width: 150px;
            height: 210px;
            border-radius: 12px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            transition: all 0.6s ease;
            border: 1px solid rgba(255, 255, 255, 0.4);
            box-shadow: 5px 5px 15px rgba(0,0,0,0.1);
        }

        /* Estado Inicial Empilhado e Centralizado */
        .sheet:nth-child(1) { 
            background: rgba(255, 255, 255, 1); 
            z-index: 3; 
            transform: rotateX(50deg) rotateZ(-5deg);
        }
        .sheet:nth-child(2) { 
            background: rgba(255, 255, 255, 0.6); 
            backdrop-filter: blur(4px);
            z-index: 2; 
            transform: rotateX(50deg) rotateZ(-5deg) translate(8px, 8px);
        }
        .sheet:nth-child(3) { 
            background: rgba(255, 255, 255, 0.2); 
            backdrop-filter: blur(8px);
            z-index: 1; 
            transform: rotateX(50deg) rotateZ(-5deg) translate(16px, 16px);
        }

        .sheet span, .sheet p {
            opacity: 0;
            color: #4b0082;
            font-weight: bold;
            margin: 5px 0;
        }

        /* --- Hover: Espaçamento e Aumento --- */

        /* Cria o espaço entre as abas ao abrir */
        .circle-container:hover .sheet {
            background: rgba(255, 255, 255, 1);
            transform: rotateX(0) rotateZ(0) scale(1.15); /* Aumentam de tamanho */
            position: relative; /* Sai do empilhamento fixo */
            margin: 0 25px;    /* ESQUERDA/DIREITA: Garante o espaço entre elas */
            box-shadow: 0 15px 35px rgba(0,0,0,0.2);
        }

        .circle-container:hover .sheet span,
        .circle-container:hover .sheet p {
            opacity: 1;
        }

        .sheet span { font-size: 2.5rem; }
    </style>
</head>
<body>

    <div class="circle-container">
        <div class="stack-wrapper">
            
            <div class="sheet">
                <span>🗂️</span>
                <p>Flashcards</p>
            </div>

            <div class="sheet">
                <span>📝</span>
                <p>Anotações</p>
            </div>

            <div class="sheet">
                <span>📖</span>
                <p>Resumo</p>
            </div>

        </div>
    </div>

</body>
</html>
